"<!DOCTYPE html>\r\n<html xmlns=\"http://www.w3.org/1999/xhtml\">\r\n<head>\r\n    <meta http-equiv=\"Content-Type\" content=\"text/html; charset=utf-8\" />\r\n    <title>无F10资料</title>\r\n    <style type=\"text/css\">\r\n        .parent {\r\n            position: fixed;\r\n            top: 50%;\r\n            bottom: 50%;\r\n            left: 50%;\r\n            right: 50%;\r\n            width: 0;\r\n            height: 0;\r\n        }\r\n\r\n        .show {\r\n            border: 0px solid red;\r\n            width: 20rem;\r\n            /* 以下两个属性必须为width,height值的负一半 */\r\n            margin-left: -10rem;\r\n            margin-top: -60px;\r\n            text-align: center;\r\n        }\r\n\r\n        table {\r\n            width: 100%;\r\n            height: 100%;\r\n            text-align: center;\r\n        }\r\n\r\n        td {\r\n            border: 1px solid red;\r\n        }\r\n    </style>\r\n</head>\r\n<body style=\"background-color: #070707;\">\r\n    <div class=\"parent\">\r\n        <div class=\"show\">\r\n            <img id=\"loadImg\" src=\"../Content/img/noData_b.png\" />\r\n        </div>\r\n    </div>\r\n</body>\r\n</html>\r\n<script>\r\n    window.onload = function () {\r\n        var skin = GetQueryString(\"type\");\r\n        var color = GetQueryString(\"color\");\r\n        if (skin && skin == \"web\" || color==\"w\") {\r\n            document.getElementById(\"loadImg\").src = \"../Content/img/noData_w.png\";\r\n            document.getElementsByTagName(\"body\")[0].style.backgroundColor = \"#ffffff\";\r\n        }\r\n    };\r\n\r\n    function GetQueryString(name) {\r\n        var reg = new RegExp(\"(^|&)\" + name + \"=([^&]*)(&|$)\");\r\n        var r = window.location.search.substr(1).match(reg);\r\n        if (r != null) return unescape(r[2]); return null;\r\n    }\r\n</script>\r\n"